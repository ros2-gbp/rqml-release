plugins:
  - id: default_plugins.action_caller
    name: "Action Caller"
    group: "Communication"
    path: "share/@PROJECT_NAME@/qml/ActionCaller.qml"
    single_instance: false
  - id: default_plugins.console
    name: "Console"
    group: "Introspection"
    path: "share/@PROJECT_NAME@/qml/Console.qml"
    single_instance: false
  - id: default_plugins.controller_manager
    name: "Controller Manager"
    group: "Control"
    path: "share/@PROJECT_NAME@/qml/ControllerManager.qml"
    single_instance: false
  - id: default_plugins.controller_manager_statistics
    name: "Controller Manager Statistics"
    group: "Introspection"
    path: "share/@PROJECT_NAME@/qml/ControllerManagerStatistics.qml"
    single_instance: false
  - id: default_plugins.image_view
    name: "Image View"
    group: "Video"
    path: "share/@PROJECT_NAME@/qml/ImageView.qml"
    single_instance: false
  - id: default_plugins.joint_trajectory_controller
    name: "Joint Trajectory Controller"
    group: "Control"
    path: "share/@PROJECT_NAME@/qml/JointTrajectoryController.qml"
    single_instance: false
  - id: default_plugins.moveit_controller
    name: "MoveIt Controller"
    group: "Control"
    path: "share/@PROJECT_NAME@/qml/MoveItController.qml"
    single_instance: false
  - id: default_plugins.message_publisher
    name: "Message Publisher"
    group: "Communication"
    path: "share/@PROJECT_NAME@/qml/MessagePublisher.qml"
    single_instance: false
  - id: default_plugins.parameter_editor
    name: "Parameter Editor"
    group: "Configuration"
    path: "share/@PROJECT_NAME@/qml/ParameterEditor.qml"
    single_instance: false
  - id: default_plugins.robot_steering
    name: "Robot Steering"
    group: "Control"
    path: "share/@PROJECT_NAME@/qml/RobotSteering.qml"
    single_instance: false
  - id: default_plugins.service_caller
    name: "Service Caller"
    group: "Communication"
    path: "share/@PROJECT_NAME@/qml/ServiceCaller.qml"
    single_instance: false
  - id: default_plugins.tf_tree_viewer
    name: "TF Tree Viewer"
    group: "Introspection"
    path: "share/@PROJECT_NAME@/qml/TfTreeViewer.qml"
    single_instance: false
  - id: default_plugins.topic_monitor
    name: "Topic Monitor"
    group: "Introspection"
    path: "share/@PROJECT_NAME@/qml/TopicMonitor.qml"
    single_instance: false
